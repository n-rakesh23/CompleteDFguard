# Server
PORT=8000
NODE_ENV=development
FRONTEND_URL=https://yourdomain.com

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/dfguard

# Redis (ElastiCache or local)
REDIS_URL=redis://localhost:6379

# AWS
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-south-1

# Cognito
COGNITO_USER_POOL_ID=ap-south-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# S3
S3_BUCKET=dfguard-images-prod

# SQS
SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/ACCOUNT_ID/dfguard-jobs

# SNS
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:ACCOUNT_ID:dfguard-notifications

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Secrets Manager (production only — leave blank in dev)
USE_SECRETS_MANAGER=false
